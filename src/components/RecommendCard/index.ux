<template>
  <div class="c-recommend-card" onclick="handleTap">
    <stack class="c-recommend-cover-wrap">
      <image class="c-recommend-cover" src="{{ item.cover }}"></image>
      <div class="c-recommend-cover-mask"></div>
      <text class="c-recommend-tag" if="{{ item.tag }}">✦ {{ item.tag }}</text>
    </stack>
    <div class="c-recommend-body">
      <text class="c-recommend-title">{{ item.title }}</text>
      <text class="c-recommend-sub">{{ item.subtitle }}</text>
    </div>
  </div>
</template>

<script>
export default {
  props: {
    item: {
      type: Object,
      default: {}
    }
  },

  handleTap() {
    this.$emit('click', { item: this.item })
  }
}
</script>

<style lang="less">
