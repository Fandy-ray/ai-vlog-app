<template>
  <div class="c-memory-card" onclick="handleTap">
    <stack class="c-memory-cover-wrap">
      <image class="c-memory-cover" src="{{ item.cover }}"></image>
      <div class="c-memory-cover-mask"></div>
      <text class="c-memory-duration" if="{{ item.duration }}">{{ item.duration }}</text>
      <text class="c-memory-play">▶</text>
    </stack>
    <div class="c-memory-body">
      <text class="c-memory-title">{{ item.title }}</text>
      <text class="c-memory-meta">{{ item.views }} 次观看</text>
    </div>
  </div>
</template>

<script>
export default {
  props: {
    item: {
      type: Object,
      default: {}
    }
  },

  handleTap() {
    this.$emit('click', { item: this.item })
  }
}
</script>

