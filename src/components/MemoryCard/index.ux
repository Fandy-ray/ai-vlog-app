  width: 100%;
  height: 248px;
}

.c-memory-cover {
  width: 100%;
  height: 248px;
  object-fit: cover;
}

.c-memory-cover-mask {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 120px;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.45), transparent);
}

.c-memory-duration {
  position: absolute;
  right: 16px;
  bottom: 16px;
  padding: 4px 12px;
  border-radius: 8px;
  background-color: rgba(0, 0, 0, 0.5);
  color: @white;
  font-size: 20px;
}

.c-memory-play {
  position: absolute;
  left: 16px;
  bottom: 16px;
  width: 48px;
  height: 48px;
  border-radius: 24px;
  background-color: rgba(255, 255, 255, 0.25);
  color: @white;
  font-size: 20px;
  text-align: center;
  padding-top: 10px;
}

.c-memory-body {
  padding: 16px 20px 20px 20px;
