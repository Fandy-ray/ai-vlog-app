  height: 70px;
  margin-bottom: 16px;
  border-radius: 10px;
  background-color: #e9ebee;
  color: #111111;
  font-size: 29px;
}

.primary {
  background-color: #2f6f58;
  color: #ffffff;
}

.ghost {
  background-color: #ffffff;
  color: #2f6f58;
}

.empty {
  flex-direction: column;
  justify-content: center;
  align-items: center;
  min-height: 220px;
  padding: 28px;
  border-radius: 10px;
  background-color: #ffffff;
  margin-bottom: 22px;
}

.empty-title {
  font-size: 30px;
  color: #12181f;
  margin-bottom: 10px;
}

.empty-text {
  font-size: 24px;
  color: #8a9098;
  text-align: center;
}

.materials {
  flex-direction: column;
  margin-bottom: 22px;
}

.material {
  flex-direction: row;
  align-items: center;
  padding: 22px;
  margin-bottom: 16px;
  border-radius: 10px;
  background-color: #ffffff;
}

.material-main {
  flex: 1;
  flex-direction: column;
}

.material-name {
  font-size: 28px;
  color: #12181f;
  margin-bottom: 8px;
}

.material-meta {
  font-size: 22px;
  color: #456b86;
  margin-bottom: 6px;
}

.material-uri {
  font-size: 20px;
  color: #9aa0a8;
}

.remove {
  width: 76px;
  text-align: right;
  font-size: 24px;
  color: #b55b4f;
}

