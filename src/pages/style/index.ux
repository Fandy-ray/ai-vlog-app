  flex-direction: column;
}

.option {
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 24px;
  margin-bottom: 18px;
  border-radius: 10px;
  background-color: #ffffff;
  border-width: 2px;
  border-color: #ffffff;
}

.option-active {
  border-color: #2f6f58;
  background-color: #eef5f1;
}

.option-main {
  flex: 1;
  flex-direction: column;
}

.option-title {
  font-size: 30px;
  color: #12181f;
  margin-bottom: 8px;
}

.option-desc {
  font-size: 23px;
  color: #7c838b;
}

.option-mark {
  width: 76px;
  text-align: right;
  font-size: 24px;
  color: #2f6f58;
}

.template-list {
  flex-direction: column;
  margin-top: 8px;
  margin-bottom: 28px;
}

.template {
  flex-direction: column;
  padding: 22px;
  margin-bottom: 16px;
  border-radius: 10px;
  background-color: #ffffff;
  border-width: 2px;
  border-color: #ffffff;
}

.template-active {
  border-color: #456b86;
  background-color: #eef3f6;
}

.template-name {
  font-size: 28px;
  color: #12181f;
  margin-bottom: 8px;
}

.template-meta {
  font-size: 23px;
  color: #7c838b;
}

.actions {
  flex-direction: column;
}

.btn {
  height: 70px;
  margin-bottom: 18px;
  border-radius: 10px;
  background-color: #e9ebee;
  color: #111111;
