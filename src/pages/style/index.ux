<template>
  <div class="page">
    <text class="heading">选择 Vlog 类型</text>
    <text class="hint">类型会影响拍摄指引、默认素材和生成脚本。</text>

    <div class="section">
      <block for="{{ (index, item) in types }}">
        <div
          class="option {{ selectedType === item.type ? 'option-active' : '' }}"
          data-type="{{ item.type }}"
          data-style="{{ item.defaultStyle }}"
          onclick="selectType"
        >
          <div class="option-main">
            <text class="option-title">{{ item.name }}</text>
            <text class="option-desc">{{ item.description || item.desc }}</text>
          </div>
          <text class="option-mark">{{ selectedType === item.type ? '已选' : '选择' }}</text>
        </div>
      </block>
    </div>

    <text class="heading small">视觉风格</text>
    <div class="template-list">
      <block for="{{ (index, item) in styles }}">
        <div
          class="template {{ selectedStyle === item.id ? 'template-active' : '' }}"
          data-style="{{ item.id }}"
          onclick="selectStyle"
        >
          <text class="template-name">{{ item.name }}</text>
          <text class="template-meta">{{ item.filterName }} / {{ item.bgmName }}</text>
        </div>
      </block>
    </div>

    <div class="actions">
      <input class="btn primary" type="button" value="进入拍摄指引" onclick="goShoot" />
      <input class="btn" type="button" value="返回首页" onclick="goHome" />
    </div>
  </div>
</template>

<script>
import router from '@system.router'
import vlogApi from '../../helper/apis/vlog'
import store from '../../helper/store'
import $utils from '../../helper/utils'

export default {
  private: {
    types: [],
    styles: [],
    selectedType: 'study',
    selectedStyle: 'study'
  },

  onInit() {
    this.$page.setTitleBar({ text: '风格' })
    this.selectedType = store.state.type || 'study'
    this.selectedStyle = store.state.style || 'study'
    this.loadOptions()
  },

  loadOptions() {
    vlogApi
      .getVlogTypes()
      .then(types => {
        this.types = types || []
        store.setState({ types: this.types })
      })
      .catch(() => {
        $utils.showToast('类型加载失败')
      })

    vlogApi
      .getStyleTemplates()
      .then(styles => {
        this.styles = styles || []
        store.setState({ styles: this.styles })
      })
      .catch(() => {
        $utils.showToast('风格加载失败')
      })
  },

  selectType(event) {
    const dataset = event.currentTarget.dataset
    this.selectedType = dataset.type

    if (dataset.style) {
      this.selectedStyle = dataset.style
    }

    store.resetFlow()
    store.setState({
      type: this.selectedType,
      style: this.selectedStyle
    })
  },

  selectStyle(event) {
    this.selectedStyle = event.currentTarget.dataset.style
    store.resetFlow()
    store.setState({
      type: this.selectedType,
      style: this.selectedStyle
    })
  },

  goShoot() {
    store.setState({
      type: this.selectedType,
      style: this.selectedStyle
    })
    router.push({ uri: '/pages/shoot' })
  },

  goHome() {
    router.push({ uri: '/pages/home' })
  }
}
</script>

